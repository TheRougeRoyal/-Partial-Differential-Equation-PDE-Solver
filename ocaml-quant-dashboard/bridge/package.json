{
  "name": "ocaml-quant-bridge",
  "version": "1.0.0",
  "description": "Node.js bridge server for OCaml Quant Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "check": "npm run lint && npm run build",
    "start": "PORT=${PORT:-3002} node dist/index.js",
    "test": "jest",
    "simulate": "node simulate_live.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
